# Solo necesario para desarrollo local y para compilar la APK en modo desarrollo (misma red).
# En desarrollo web (npm run dev) se usa el proxy /api → localhost:4000.
#
# Desarrollo local / APK en red local:
#   VITE_API_URL=http://192.168.1.100:4000/api
#
# Para APK que funcione desde cualquier lugar: no pongas nada aquí y deja que
# el build de producción use .env.production (URL pública del servidor).
VITE_API_URL=
