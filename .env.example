# =============================================================================
# Variables de entorno — raíz del repo (Docker Compose)
# =============================================================================
# Compose usa este archivo (o `env`) para sustituir ${POSTGRES_*} al crear el servicio `db`
# y la cadena DATABASE_URL del servicio `backend`. NO es el mismo archivo que backend/.env:
#   - backend/.env  → secretos de la API (copiá desde backend/.env.example). Nunca commitear.
#   - .env o env aquí → mismos POSTGRES_* que en backend/.env si querés un solo origen de verdad
#     para la contraseña del volumen Postgres (ver scripts/docker-compose-env.sh).
#
# Producción: JWT_SECRET, FRONTEND_URL y SQL Server van en backend/.env; acá solo Postgres si hace falta.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (contenedor Docker) - la base se crea automáticamente al levantar Docker
# Estos son los valores del proyecto; el backend se conecta por DATABASE_URL que arma docker-compose.
# -----------------------------------------------------------------------------
POSTGRES_USER=compras_verdu
POSTGRES_PASSWORD=compras_verdu_secret
POSTGRES_DB=compras_verdu

# -----------------------------------------------------------------------------
# Backend (API) — en Docker van en backend/.env; duplicar aquí solo si usás un único `env`/`env`-file
# JWT: mínimo 32 caracteres en producción (openssl rand -base64 48)
# FRONTEND_URL: HTTPS público del front (CORS), ej. https://cverdu.elabastecedor.com.ar
# -----------------------------------------------------------------------------
JWT_SECRET=cambiar-clave-secreta-muy-segura-en-produccion-minimo-32-caracteres
FRONTEND_URL=https://cverdu.elabastecedor.com.ar
# Local sin HTTPS: FRONTEND_URL=http://localhost:8081

# SSO desde Tablero (token `tablero_sso` firmado HS256)
# Debe coincidir con el secreto configurado en Tablero para Compras Verdu.
TABLERO_SSO_SECRET=cambiar-secreto-sso-cverdu

# -----------------------------------------------------------------------------
# SQL Server externo (El Abastecedor) - obligatorias si usás integración
# Usuario: shs. Sin contraseña.
# -----------------------------------------------------------------------------
EXTERNAL_DB_SERVER=192.168.1.200
EXTERNAL_DB_PORT=1433
EXTERNAL_DB_DATABASE=ELABASTECEDOR
EXTERNAL_DB_USER=shs
EXTERNAL_DB_PASSWORD=

# Login contra dbo.Usuarios (código / usuario / email). Producción con Abastecedor: true
EXTERNAL_AUTH_LOGIN=true

# Tabla/columnas Usuarios en SQL Server (misma red LAN que el host Docker). Ver backend/.env.example.
EXTERNAL_USUARIOS_TABLE=Usuarios
EXTERNAL_USUARIOS_COL_ID=Codigo
EXTERNAL_USUARIOS_COL_EMAIL=EMail
EXTERNAL_USUARIOS_COL_USUARIO=Usuario
EXTERNAL_USUARIOS_MATCH_USUARIO=true
EXTERNAL_USUARIOS_COL_PASSWORD=Clave
EXTERNAL_USUARIOS_COL_NIVEL=Nivel
EXTERNAL_USUARIOS_COL_NOMBRE=NombreCompleto
EXTERNAL_USUARIOS_COL_ACTIVO=Habilitado
EXTERNAL_USUARIOS_PASSWORD_MODE=auto
EXTERNAL_USUARIOS_LIST_LIMIT=2000

# -----------------------------------------------------------------------------
# SQL Server - Proveedores (por defecto: proveedores / codigo / Nombre)
# Sólo descomentá si tu base usa otros nombres de tabla o columnas.
# -----------------------------------------------------------------------------
# EXTERNAL_PROVEEDORES_TABLE=proveedores
# EXTERNAL_PROVEEDORES_PK=codigo
# EXTERNAL_PROVEEDORES_ID=codigo
# EXTERNAL_PROVEEDORES_NOMBRE=Nombre

# -----------------------------------------------------------------------------
# SQL Server - Artículos (por defecto: articulos y columnas estándar El Abastecedor)
# EXTERNAL_ARTICULOS_DEPARTAMENTO_ID=6 es el departamento verdulería.
# -----------------------------------------------------------------------------
# EXTERNAL_ARTICULOS_TABLE=articulos
# EXTERNAL_ARTICULOS_CODIGO=codigo
# EXTERNAL_ARTICULOS_DESCRIPCION=descripcion
# EXTERNAL_ARTICULOS_HABILCAJAS=habilcajas
# EXTERNAL_ARTICULOS_DEPARTAMENTO=departamento
# EXTERNAL_ARTICULOS_PROVEEDOR=proveedor
EXTERNAL_ARTICULOS_DEPARTAMENTO_ID=6
# EXTERNAL_ARTICULOS_IVA=IVA
# EXTERNAL_ARTICULOS_PRECIO_COSTO=PrecioCosto
# EXTERNAL_ARTICULOS_PRECIO_VENTA=PrecioVenta
# EXTERNAL_ARTICULOS_MARGEN=Margen
# EXTERNAL_ARTICULOS_UXB=UxB

# -----------------------------------------------------------------------------
# SQL Server - Tabla IVA (por defecto: TablaIVA, Codigo, Porcentaje)
# -----------------------------------------------------------------------------
# EXTERNAL_IVA_TABLE=TablaIVA
# EXTERNAL_IVA_CODIGO=Codigo
# EXTERNAL_IVA_PORCENTAJE=Porcentaje

# -----------------------------------------------------------------------------
# SQL Server - Stock (por defecto: Stock, sucursal, codigo, stock)
# -----------------------------------------------------------------------------
# EXTERNAL_STOCK_TABLE=Stock
# EXTERNAL_STOCK_SUCURSAL=sucursal
# EXTERNAL_STOCK_CODIGO=codigo
# EXTERNAL_STOCK_STOCK=stock

# -----------------------------------------------------------------------------
# SQL Server - Ventas por artículo (por defecto: VTAARTICULOS y columnas estándar)
# -----------------------------------------------------------------------------
# EXTERNAL_VTA_TABLE=VTAARTICULOS
# EXTERNAL_VTA_FECHA=FECHA
# EXTERNAL_VTA_SUCURSAL=SUCURSAL
# EXTERNAL_VTA_CODIGO=CODIGO
# EXTERNAL_VTA_CANTIDAD=CANTIDAD
# EXTERNAL_VTA_IMPORTE=IMPORTE
# EXTERNAL_VTA_COSTO=COSTO
