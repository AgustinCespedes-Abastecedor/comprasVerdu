# Dependencias
node_modules/

# Entorno y secretos (nunca commitear; usá *.env.example como plantilla)
.env
env
backend/.env
.env.local
.env.*.local

# Build y cache
frontend/dist/
frontend/.vite/
backend/generated/

# Imágenes de artículos (solo en disco local o en el servidor de build; no versionar)
img/

# Copia local para empaquetar en la APK (frontend/scripts/ensure-public-img.mjs)
frontend/public/img/**
!frontend/public/img/.gitkeep

# Snapshot de roles (generado con npm run db:export-roles; no versionar)
backend/roles-export.json

# Logs y OS
*.log
.DS_Store
Thumbs.db
