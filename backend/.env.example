# Con Docker: puerto 5433 (evita conflicto con PostgreSQL local en 5432)
DATABASE_URL="postgresql://compras_verdu:compras_verdu_secret@localhost:5433/compras_verdu?schema=public"
# En producción es obligatorio: mínimo 32 caracteres. Generar con: openssl rand -base64 32
JWT_SECRET="cambiar-por-un-secreto-seguro-en-produccion"
PORT=4000
FRONTEND_URL="http://localhost:5173"

# SQL Server externo (El Abastecedor) - proveedores
EXTERNAL_DB_SERVER=192.168.1.200
EXTERNAL_DB_PORT=1433
EXTERNAL_DB_DATABASE=ELABASTECEDOR
EXTERNAL_DB_USER=shs
EXTERNAL_DB_PASSWORD=

# Login contra tabla Usuarios en ELABASTECEDOR (sin registro público en la app).
# EXTERNAL_AUTH_LOGIN=true
# EXTERNAL_USUARIOS_TABLE=Usuarios
# EXTERNAL_USUARIOS_COL_ID=Codigo
# EXTERNAL_USUARIOS_COL_EMAIL=EMail
# EXTERNAL_USUARIOS_COL_USUARIO=Usuario
# EXTERNAL_USUARIOS_MATCH_USUARIO=true
# EXTERNAL_USUARIOS_COL_PASSWORD=Clave
# EXTERNAL_USUARIOS_COL_NIVEL=Nivel
# EXTERNAL_USUARIOS_COL_NOMBRE=NombreCompleto
# Por defecto filtra Habilitado=1. Para no filtrar: EXTERNAL_USUARIOS_IGNORE_ACTIVO=true
# EXTERNAL_USUARIOS_COL_ACTIVO=Habilitado
# Contraseña: auto (recomendado) prueba texto plano, MD5 hex, bcrypt y PWDCOMPARE en SQL Server.
# EXTERNAL_USUARIOS_PASSWORD_MODE=auto
# Rangos de Nivel → rol en Postgres (seed): Recepcionista | Comprador | Administrativo | Administrador si Nivel=100
# EXTERNAL_NIVEL_RECEP_MIN=0
# EXTERNAL_NIVEL_RECEP_MAX=20
# EXTERNAL_NIVEL_COMP_MIN=25
# EXTERNAL_NIVEL_COMP_MAX=30
# EXTERNAL_NIVEL_ADMIN_MIN=35
# EXTERNAL_NIVEL_ADMIN_MAX=40
# EXTERNAL_NIVEL_ADMIN_SISTEMA=100
# Opcional: si la tabla/columnas tienen otros nombres (por defecto PK=codigo; si tu tabla tiene columna Id, usá EXTERNAL_PROVEEDORES_PK=Id)
# EXTERNAL_PROVEEDORES_TABLE=proveedores
# EXTERNAL_PROVEEDORES_PK=codigo
# EXTERNAL_PROVEEDORES_ID=codigo
# EXTERNAL_PROVEEDORES_NOMBRE=Nombre

# SQL Server — lista extra de proveedores por grupo (Agrupados / AgrupadosDetalle)
# Se unen a la lista blanca CODIGOS_PROVEEDORES_PERMITIDOS en GET /proveedores.
# Agrupados: columna GRUPO es la clave. AgrupadosDetalle: GRUPO = Agrupados.GRUPO; codigo = código de proveedor
#   (mismo que proveedores en SQL Server; el nombre en la app sale de sync fetchProveedoresExternos + Prisma).
# Valor de grupo: prioridad EXTERNAL_AGRUPADOS_GRUPO_ID → búsqueda en Agrupados por EXTERNAL_AGRUPADOS_GRUPO_CODIGO_TABLA
#   (columna codigo o GRUPO) → EXTERNAL_AGRUPADOS_GRUPO_ID_DEFAULT (44).
# EXTERNAL_AGRUPADOS_USAR_DETALLE=true
# EXTERNAL_AGRUPADOS_TABLE=Agrupados
# EXTERNAL_AGRUPADOS_COL_GRUPO=GRUPO
# EXTERNAL_AGRUPADOS_COL_CODIGO=codigo
# EXTERNAL_AGRUPADOS_DETALLE_TABLE=AgrupadosDetalle
# EXTERNAL_AGRUPADOS_DETALLE_GRUPO_COL=GRUPO
# EXTERNAL_AGRUPADOS_DETALLE_CODIGO_COL=codigo
# EXTERNAL_AGRUPADOS_GRUPO_ID=
# EXTERNAL_AGRUPADOS_GRUPO_CODIGO_TABLA=
# EXTERNAL_AGRUPADOS_GRUPO_ID_DEFAULT=44

# SQL Server - artículos (habilcajas=1, departamento=6)
# EXTERNAL_ARTICULOS_TABLE=articulos
# EXTERNAL_ARTICULOS_CODIGO=codigo
# EXTERNAL_ARTICULOS_DESCRIPCION=descripcion
# EXTERNAL_ARTICULOS_HABILCAJAS=habilcajas
# EXTERNAL_ARTICULOS_DEPARTAMENTO=departamento
# EXTERNAL_ARTICULOS_PROVEEDOR=proveedor
# EXTERNAL_ARTICULOS_DEPARTAMENTO_ID=6
# EXTERNAL_ARTICULOS_IVA=IVA
# EXTERNAL_ARTICULOS_PRECIO_COSTO=PrecioCosto
# EXTERNAL_ARTICULOS_PRECIO_VENTA=PrecioVenta
# EXTERNAL_ARTICULOS_MARGEN=Margen

# SQL Server - TablaIVA (Codigo, Porcentaje ej. 21.000=21% 10.5000=10.5%); articulos.IVA referencia Codigo
# EXTERNAL_IVA_TABLE=TablaIVA
# EXTERNAL_IVA_CODIGO=Codigo
# EXTERNAL_IVA_PORCENTAJE=Porcentaje

# SQL Server - Stock (en ELABASTECEDOR: tabla Stock, columnas Sucursal, Codigo, Stock tipo MONEY)
# EXTERNAL_STOCK_TABLE=Stock
# EXTERNAL_STOCK_SUCURSAL=sucursal
# EXTERNAL_STOCK_CODIGO=codigo
# EXTERNAL_STOCK_STOCK=stock
