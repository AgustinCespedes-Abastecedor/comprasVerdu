# Copiá a .env. En producción con Docker (docker-compose.yml), el backend usa env_file: ./backend/.env
# y Compose fuerza NODE_ENV=production y DATABASE_URL=@db:5432.

NODE_ENV=development
PORT=4000

POSTGRES_USER=compras_verdu
POSTGRES_PASSWORD=compras_verdu_secret
POSTGRES_DB=compras_verdu
DATABASE_URL="postgresql://compras_verdu:compras_verdu_secret@127.0.0.1:5433/compras_verdu?schema=public"

JWT_SECRET="definir-secreto-largo-minimo-32-caracteres-produccion"
FRONTEND_URL=https://cverdu.elabastecedor.com.ar

EXTERNAL_DB_SERVER=192.168.1.200
EXTERNAL_DB_PORT=1433
EXTERNAL_DB_DATABASE=ELABASTECEDOR
EXTERNAL_DB_USER=shs
EXTERNAL_DB_PASSWORD=

EXTERNAL_AUTH_LOGIN=true
EXTERNAL_USUARIOS_TABLE=Usuarios
EXTERNAL_USUARIOS_COL_ID=Codigo
EXTERNAL_USUARIOS_COL_EMAIL=EMail
EXTERNAL_USUARIOS_COL_USUARIO=Usuario
EXTERNAL_USUARIOS_MATCH_USUARIO=true
EXTERNAL_USUARIOS_COL_PASSWORD=Clave
EXTERNAL_USUARIOS_COL_NIVEL=Nivel
EXTERNAL_USUARIOS_COL_NOMBRE=NombreCompleto
# Opcional: columnas del modal «Detalle» (por defecto Legajo, Sucursal, Sector, Telefono, Interno)
# EXTERNAL_USUARIOS_COL_LEGAJO=Legajo
# EXTERNAL_USUARIOS_COL_SUCURSAL=Sucursal
# EXTERNAL_USUARIOS_COL_SECTOR=Sector
# EXTERNAL_USUARIOS_COL_TELEFONO=Telefono
# EXTERNAL_USUARIOS_COL_INTERNO=Interno
EXTERNAL_USUARIOS_COL_ACTIVO=Habilitado
EXTERNAL_USUARIOS_PASSWORD_MODE=auto
EXTERNAL_USUARIOS_LIST_LIMIT=2000

EXTERNAL_ARTICULOS_DEPARTAMENTO_ID=6
