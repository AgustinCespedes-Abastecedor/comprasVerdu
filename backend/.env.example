# =============================================================================
# Backend Compras Verdu — plantilla (NO commitear .env con secretos reales)
# =============================================================================
# Producción Docker (docker compose en la raíz del repo):
#   - Copiá este archivo a backend/.env y completá JWT_SECRET, EXTERNAL_DB_PASSWORD si aplica.
#   - docker-compose.yml usa env_file: ./backend/.env y SOBRESCRIBE en el contenedor:
#       NODE_ENV=production, PORT=4000,
#       DATABASE_URL → postgresql://...@db:5432/... (servicio Postgres del compose, no 127.0.0.1).
#   - El DATABASE_URL que figura abajo es para desarrollo local (npm run dev); en el contenedor lo ignora Compose.
# FRONTEND_URL = URL pública HTTPS (CORS). Debe coincidir con cómo entran los usuarios al front.
#
# Sustitución ${POSTGRES_*} en docker-compose.yml: Compose lee variables del host desde
#   `env` o `.env` en la RAÍZ (ver scripts/docker-compose-env.sh). Los POSTGRES_* de abajo deben
#   coincidir con el volumen de Postgres (no cambiar contraseña sin recrear volumen o migrar).
# =============================================================================

NODE_ENV=development
PORT=4000

POSTGRES_USER=compras_verdu
POSTGRES_PASSWORD=compras_verdu_secret
POSTGRES_DB=compras_verdu
# Local: Postgres en el host (5433 = docker-compose.db.yml por defecto).
DATABASE_URL="postgresql://compras_verdu:compras_verdu_secret@127.0.0.1:5433/compras_verdu?schema=public"

# Producción: mínimo 32 caracteres. Generar: openssl rand -base64 48
JWT_SECRET="definir-secreto-largo-minimo-32-caracteres-produccion"
FRONTEND_URL=https://cverdu.elabastecedor.com.ar

# SSO desde Tablero (token `tablero_sso` firmado HS256)
# Debe coincidir con el secreto configurado en Tablero para Compras Verdu.
TABLERO_SSO_SECRET="definir-secreto-largo"

EXTERNAL_DB_SERVER=192.168.1.200
EXTERNAL_DB_PORT=1433
EXTERNAL_DB_DATABASE=ELABASTECEDOR
EXTERNAL_DB_USER=shs
EXTERNAL_DB_PASSWORD=

EXTERNAL_AUTH_LOGIN=true
EXTERNAL_USUARIOS_TABLE=Usuarios
EXTERNAL_USUARIOS_COL_ID=Codigo
EXTERNAL_USUARIOS_COL_EMAIL=EMail
EXTERNAL_USUARIOS_COL_USUARIO=Usuario
EXTERNAL_USUARIOS_MATCH_USUARIO=true
EXTERNAL_USUARIOS_COL_PASSWORD=Clave
EXTERNAL_USUARIOS_COL_NIVEL=Nivel
EXTERNAL_USUARIOS_COL_NOMBRE=NombreCompleto
# Opcional: columnas del modal «Detalle» (por defecto Legajo, Sucursal, Sector, Telefono, Interno)
# EXTERNAL_USUARIOS_COL_LEGAJO=Legajo
# EXTERNAL_USUARIOS_COL_SUCURSAL=Sucursal
# EXTERNAL_USUARIOS_COL_SECTOR=Sector
# EXTERNAL_USUARIOS_COL_TELEFONO=Telefono
# EXTERNAL_USUARIOS_COL_INTERNO=Interno
EXTERNAL_USUARIOS_COL_ACTIVO=Habilitado
# auto incluye cifrado legado ELAB (Clave NVARCHAR +15/-17) además de plain, MD5, PWDCOMPARE…
EXTERNAL_USUARIOS_PASSWORD_MODE=auto
# Solo legado ELAB: EXTERNAL_USUARIOS_PASSWORD_MODE=elab_legacy
EXTERNAL_USUARIOS_LIST_LIMIT=2000

EXTERNAL_ARTICULOS_DEPARTAMENTO_ID=6

# Info final de artículos / calendario de recepciones: hora UTC que representa medianoche local (Argentina ART = 3).
# APP_CALENDAR_UTC_START_HOUR=3
